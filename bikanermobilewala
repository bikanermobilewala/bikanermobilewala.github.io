function waLink(product) {
  const text = product
    ? `Hi Bikaner Mobilewala, I'm interested in the ${product.name} ${product.storage}${
        product.note ? " (" + product.note + ")" : ""
      }. Please share the price and availability.`
    : "Hi Bikaner Mobilewala, I'd like to know more about your iPhones.";
  return `https://wa.me/${WA_1}?text=${encodeURIComponent(text)}`;
}

function PhoneMockup({ color, size = "normal" }) {
  const h = size === "large" ? 380 : size === "small" ? 170 : 240;
  const w = h * 0.56;
  return (
    <div
      className="phone-mock"
      style={{ width: w, height: h, background: COLOR_SWATCH[color] || COLOR_SWATCH["Black Titanium"] }}
