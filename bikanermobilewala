              <span className="txt">Surat, Gujarat</span>
              <span className="rule" />
            </div>
            <img className="hero-logo" src={LOGO_URL} alt="Bikaner Mobilewala" />
            <h1>Bikaner Mobilewala</h1>
            <p className="sub">Certified authentic. Every unit verified, every customer trusted — a premium Apple buying experience, 24 hours a day.</p>
            <div className="hero-ctas">
              <button className="btn-primary" onClick={() => setPage("products")}>Explore the Collection</button>
              <a className="btn-secondary" href={waLink()} target="_blank" rel="noopener noreferrer">Chat on WhatsApp</a>
            </div>
          </section>

          <div className="trust">
            <div><h5>Certified</h5><p>100% genuine Apple devices</p></div>
            <div><h5>Verified</h5><p>Every unit checked before sale</p></div>
            <div><h5>Local</h5><p>Trusted store in Surat</p></div>
            <div><h5>Always Open</h5><p>24 × 7 support</p></div>
          </div>

          <section className="section">
            <div className="section-head">
              <p className="eyebrow">Featured</p>
              <h2>The current collection</h2>
              <p>A glimpse of what's in store right now.</p>
            </div>
            <div className="grid">
              {PRODUCTS.slice(0, 4).map((p) => (
                <ProductCard key={p.id} p={p} onOpen={openProduct} />
              ))}
            </div>
            <div className="view-all-wrap">
              <button className="btn-primary" onClick={() => setPage("products")}>View all iPhones</button>
            </div>
          </section>

          <div className="cta-band">
            <h2>Got a question about a model?</h2>
            <p>We reply fast on WhatsApp — no waiting, no bots.</p>
            <a className="btn-primary" href={waLink()} target="_blank" rel="noopener noreferrer">Message us now</a>
          </div>
        </>
      )}

      {page === "products" && (
        <section className="section" style={{ paddingTop: 60 }}>
          <div className="section-head">
            <p className="eyebrow">Shop</p>
            <h2>The full iPhone lineup</h2>
            <p>All units certified authentic. Tap a phone for full details, or ask us the price on WhatsApp.</p>
          </div>
          <div className="grid">
            {PRODUCTS.map((p) => (
              <ProductCard key={p.id} p={p} onOpen={openProduct} />
            ))}
          </div>
        </section>
      )}

      {page === "detail" && activeProduct && (
        <div className="detail">
          <button className="back-link" onClick={() => setPage("products")}>← Back to all iPhones</button>
          <div className="detail-wrap">
            <div className="detail-stage">
              <PhoneMockup color={activeProduct.color} size="large" />
            </div>
            <div>
              <p className="detail-eyebrow">{activeProduct.storage} · {activeProduct.note || activeProduct.color}</p>
              <h1 className="detail-title">{activeProduct.name}</h1>
              <p className="detail-sub">{SPECS[activeProduct.name]?.desc}</p>

              <div className="detail-price-row">
                <div>
                  <div className="ptag">DM for price</div>
                  <div className="psub">Certified authentic · Verified unit</div>
                </div>
                <a className="btn-mini" style={{ fontSize: 13 }} href={waLink(activeProduct)} target="_blank" rel="noopener noreferrer">
                  Enquire →
                </a>
              </div>

              <div className="spec-ticket">
                <div className="spec-row"><span className="k">Storage</span><span className="v">{activeProduct.storage}</span></div>
                <div className="spec-row"><span className="k">Color</span><span className="v">{activeProduct.note || activeProduct.color}</span></div>
                <div className="spec-row"><span className="k">Display</span><span className="v">{SPECS[activeProduct.name]?.display}</span></div>
                <div className="spec-row"><span className="k">Chip</span><span className="v">{SPECS[activeProduct.name]?.chip}</span></div>
                <div className="spec-row"><span className="k">Camera</span><span className="v">{SPECS[activeProduct.name]?.camera}</span></div>
                <div className="spec-row"><span className="k">Front camera</span><span className="v">{SPECS[activeProduct.name]?.front}</span></div>
                <div className="spec-row"><span className="k">Battery</span><span className="v">{SPECS[activeProduct.name]?.battery}</span></div>
                <div className="spec-row"><span className="k">Build</span><span className="v">{SPECS[activeProduct.name]?.build}</span></div>
                <div className="spec-row"><span className="k">Connectivity</span><span className="v">{SPECS[activeProduct.name]?.connectivity}</span></div>
              </div>

              <div className="detail-cta">
                <a className="btn-primary" href={waLink(activeProduct)} target="_blank" rel="noopener noreferrer">Enquire on WhatsApp</a>
                <a className="btn-secondary" href={`tel:${PHONE_1}`}>Call to ask</a>
              </div>
            </div>
          </div>
        </div>
      )}

      {page === "about" && (
        <section className="section" style={{ paddingTop: 60 }}>
          <div className="about-wrap">
            <div className="about-copy">
              <p className="eyebrow">About us</p>
              <h2>Surat's trusted name for genuine iPhones</h2>
              <p>Bikaner Mobilewala has built its reputation on one simple promise: every iPhone we sell is certified authentic. No compromises, no shortcuts — just genuine Apple devices at fair prices.</p>
              <p>Based in Surat, Gujarat, we're available around the clock to help you find the right iPhone, answer your questions, and make sure you walk away confident in your purchase.</p>
              <ul className="about-list">
                <li><span className="dot">✓</span> 100% certified authentic devices</li>
                <li><span className="dot">✓</span> Transparent, honest pricing on request</li>
                <li><span className="dot">✓</span> Friendly, fast support — 24 × 7</li>
                <li><span className="dot">✓</span> Wide range: latest to previous-gen Pro models</li>
              </ul>
            </div>
            <div className="about-stage">
              <PhoneMockup color="Deep Blue" size="large" />
              <PhoneMockup color="Natural Titanium" size="small" />
            </div>
          </div>
        </section>
      )}

      {page === "contact" && (
        <section className="section" style={{ paddingTop: 60 }}>
          <div className="section-head">
            <p className="eyebrow">Contact</p>
            <h2>Let's talk iPhones</h2>
            <p>Reach out by call or WhatsApp — we're open 24 × 7.</p>
          </div>
          <div className="contact-wrap">
            <div className="contact-card">
              <h3>Store details</h3>
              <div className="contact-row"><span className="label">Phone</span><a href={`tel:${PHONE_1}`}>{PHONE_1}</a></div>
              <div className="contact-row"><span className="label">Phone (alt.)</span><a href={`tel:${PHONE_2}`}>{PHONE_2}</a></div>
              <div className="contact-row"><span className="label">Address</span><span className="value">{ADDRESS}</span></div>
              <div className="contact-row"><span className="label">Hours</span><span className="value">Open 24 × 7</span></div>
            </div>
            <div className="contact-panel">
              <h3>Prefer WhatsApp?</h3>
              <p>Send us a message and we'll get back within minutes.</p>
              <a className="btn-primary" href={waLink()} target="_blank" rel="noopener noreferrer">Start chat</a>
            </div>
          </div>
        </section>
      )}

      {footer}
    </div>
  );
}
